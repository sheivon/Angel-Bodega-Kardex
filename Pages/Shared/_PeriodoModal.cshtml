<!-- Modal Periodo -->
<div class="modal fade" id="periodoModal" tabindex="-1" aria-labelledby="periodoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="periodoModalLabel">Gestión de Periodos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- Form -->
                <form id="formPeriodo">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label">Id</label>
                            <input type="text" class="form-control" id="periodoId">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Año</label>
                            <input type="number" class="form-control" id="periodoAnio">
                        </div>

                        <div class="col-md-3 d-flex align-items-end">
                            <button type="button" class="btn btn-primary w-100" id="btnGuardarPeriodo">
                                Guardar
                            </button>
                        </div>
                    </div>
                </form>

                <hr>

                <!-- DataTable -->
                <div class="d-flex justify-content-end p-3">
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="printTable('#tablaPeriodos', 'Imprimir periodos')">Imprimir</button>
                </div>
                <div class="table-responsive">
                    <table id="tablaPeriodos" class="table table-striped table-bordered w-100 datatable">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Año</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Data will be loaded dynamically -->
                        </tbody>
                    </table>
                </div>

            </div>

        </div>
    </div>
</div>