@page "{id?}"
@model kardex_Web.Pages.Registrar.MovimientoModel
@{
    ViewData["Title"] = "Movimiento";
}

<div class="row">
    <div class="col-md-12">
        <h2>Gestión de Movimientos</h2>
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success" role="alert">
                @Model.StatusMessage
            </div>
        }
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">Crear / Editar movimiento</div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save">
                    <input asp-for="Input.Id" type="hidden" />

                    <div class="row gy-3">
                        <div class="col-md-2">
                            <label asp-for="Input.TipoES" class="form-label">Tipo ES</label>
                            <input asp-for="Input.TipoES" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.IdOrdCompra" class="form-label">Id Orden Compra</label>
                            <input asp-for="Input.IdOrdCompra" class="form-control" type="number" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.IdProyecto" class="form-label">Id Proyecto</label>
                            <input asp-for="Input.IdProyecto" class="form-control" type="number" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Detalle" class="form-label">Detalle</label>
                            <input asp-for="Input.Detalle" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.FechaES" class="form-label">Fecha ES</label>
                            <input asp-for="Input.FechaES" class="form-control" type="date" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.IdSalida" class="form-label">Id Salida</label>
                            <input asp-for="Input.IdSalida" class="form-control" type="number" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.IdEntrada" class="form-label">Id Entrada</label>
                            <input asp-for="Input.IdEntrada" class="form-control" type="number" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.IdProducto" class="form-label">Id Producto</label>
                            <input asp-for="Input.IdProducto" class="form-control" type="number" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.ECantidad" class="form-label">Cantidad Entrada</label>
                            <input asp-for="Input.ECantidad" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.SCantidad" class="form-label">Cantidad Salida</label>
                            <input asp-for="Input.SCantidad" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.Precio" class="form-label">Precio</label>
                            <input asp-for="Input.Precio" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.IVA" class="form-label">IVA</label>
                            <input asp-for="Input.IVA" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Input.IdAreaTrabajo" class="form-label">Id Área Trabajo</label>
                            <input asp-for="Input.IdAreaTrabajo" class="form-control" type="number" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        @if (Model.Input.Id > 0)
                        {
                            <a asp-page="/Registrar/Movimiento" class="btn btn-secondary ms-2">Cancelar</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Listado de movimientos</span>
                <button type="button" class="btn btn-outline-primary btn-sm" onclick="printTable('.datatable', 'Imprimir datos')"><i class="fa-solid fa-print me-1"></i>Imprimir</button>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped datatable mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Tipo</th>
                            <th>Fecha ES</th>
                            <th>Producto</th>
                            <th>Cantidad E</th>
                            <th>Cantidad S</th>
                            <th>Entrada</th>
                            <th>Salida</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Movimientos)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.TipoES</td>
                                <td>@item.FechaES?.ToString("yyyy-MM-dd")</td>
                                <td>@item.IdProducto</td>
                                <td>@item.ECantidad</td>
                                <td>@item.SCantidad</td>
                                <td>@item.IdEntrada</td>
                                <td>@item.IdSalida</td>
                                <td>
                                    <a asp-page="/Registrar/Movimiento" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2"><i class="fa-solid fa-pencil me-1"></i>Editar</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('¿Eliminar este movimiento?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash me-1"></i>Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
