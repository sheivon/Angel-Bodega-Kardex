@page "{id?}"
@model kardex_Web.Pages.Global.RetiraModel
@{
    ViewData["Title"] = "Retira";
}

<div class="row">
    <div class="col-md-12">
        <h2>Gestión de Retira</h2>
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success" role="alert">
                @Model.StatusMessage
            </div>
        }
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Crear / Editar retira</div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save">
                    <input asp-for="Input.Id" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Input.Cedula" class="form-label">Cédula</label>
                        <input asp-for="Input.Cedula" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NombresApellidos" class="form-label">Nombres y Apellidos</label>
                        <input asp-for="Input.NombresApellidos" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Cargo" class="form-label">Cargo</label>
                        <input asp-for="Input.Cargo" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.AyudaSocial" class="form-label">Ayuda Social</label>
                        <input asp-for="Input.AyudaSocial" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary">Guardar</button>
                    @if (Model.Input.Id > 0)
                    {
                        <a asp-page="/Global/Retira" class="btn btn-secondary ms-2">Cancelar</a>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">Listado de retira</div>
            <div class="card-body p-0">
                <div class="d-flex justify-content-end p-3">
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="printTable('.datatable', 'Imprimir datos')">Imprimir</button>
                </div>
                <table class="table table-striped datatable mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Cédula</th>
                            <th>Nombres y Apellidos</th>
                            <th>Cargo</th>
                            <th>Ayuda Social</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Retirantes)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Cedula</td>
                                <td>@item.NombresApellidos</td>
                                <td>@item.Cargo</td>
                                <td>@item.AyudaSocial</td>
                                <td>
                                    <div class="d-flex content-align-center"> 
                                        <a asp-page="/Global/Retira" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">Editar</a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('¿Eliminar este registro?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
