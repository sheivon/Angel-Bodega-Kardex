@page "{id?}"
@model kardex_Web.Pages.Global.AsignarModel
@{
    ViewData["Title"] = "Asignar";
}

<div class="row">
    <div class="col-md-12">
        <h2>Gestión de Asignaciones</h2>
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success" role="alert">
                @Model.StatusMessage
            </div>
        }
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Crear / Editar asignación</div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save">
                    <input asp-for="Input.Id" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Input.IdActivo" class="form-label">Id Activo</label>
                        <input asp-for="Input.IdActivo" class="form-control" type="number" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Fecha" class="form-label">Fecha</label>
                        <input asp-for="Input.Fecha" class="form-control" type="date" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.IdRetira" class="form-label">Id Retira</label>
                        <input asp-for="Input.IdRetira" class="form-control" type="number" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NombresApellidos" class="form-label">Nombres y Apellidos</label>
                        <input asp-for="Input.NombresApellidos" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary">Guardar</button>
                    @if (Model.Input.Id > 0)
                    {
                        <a asp-page="/Global/Asignar" class="btn btn-secondary ms-2">Cancelar</a>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">Listado de asignaciones</div>
            <div class="card-body p-0">
                <table class="table table-striped datatable mb-0">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Id Activo</th>
                            <th>Fecha</th>
                            <th>Id Retira</th>
                            <th>Nombres</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Asignaciones)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.IdActivo</td>
                                <td>@item.Fecha?.ToString("yyyy-MM-dd")</td>
                                <td>@item.IdRetira</td>
                                <td>@item.NombresApellidos</td>
                                <td>
                                    <a asp-page="/Global/Asignar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">Editar</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('¿Eliminar esta asignación?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
